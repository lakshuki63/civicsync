DATABASE_URL="postgresql://civicsync:civicsync123@localhost:5432/civicsync_db"
JWT_SECRET="civicsync-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="civicsync-refresh-secret-change-in-production"
PORT=5000
NODE_ENV=development

# Cloudinary (document storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (nodemailer - using ethereal for dev)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
EMAIL_FROM="CivicSync <noreply@civicsync.gov.in>"

# Razorpay test keys
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OTP settings
OTP_EXPIRY_MINUTES=10
